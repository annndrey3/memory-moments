# Marketplace API (Express)
#
# База даних — два режими (вибір за наявністю DATABASE_URL):
#   • DATABASE_URL не задано → SQLite-файл marketplace.db (dev, створюється сам).
#   • DATABASE_URL задано     → PostgreSQL (прод). Схема + дефолтний адмін
#     створюються автоматично; демо-каталог і прайс-лист сій через `npm run seed-data`.
#
# PostgreSQL (розкоментуй для прода). Пароль — без спецсимволів або URL-encoded:
#   DATABASE_URL=postgres://mm_app:ПАРОЛЬ@localhost:5432/memory_moments
#   DATABASE_SSL=false   # true лише для зовнішньої БД, що вимагає SSL

PORT=3001

# JWT — згенеруйте надійний ключ (>= 32 символів), сервер не стартує з дефолтним:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# CORS — список дозволених origin через кому.
# Маркетплейс (клієнт) + автономний конструктор.
CORS_ORIGIN=http://localhost:5174,http://localhost:5173

# Завантаження зображень
UPLOAD_DIR=uploads

# Seed-адміністратор (npm run seed-admin)
ADMIN_EMAIL=admin@memory-moments.local
ADMIN_PASSWORD=admin123

# Telegram-сповіщення про нові замовлення (серверні — токен секретний).
# Залиште порожнім, щоб вимкнути сповіщення.
TG_BOT_TOKEN=
TG_CHAT_ID=
