# Конструктор (designer, Vite, порт 5174)

# Посилання «на маркетплейс» (dev: основний порт)
VITE_MARKETPLACE_URL=http://localhost:5173

# База API маркетплейсу. Відносний шлях /api:
#  - dev: проксується на http://localhost:3001 (див. vite.config.js)
#  - prod: той самий origin, що й маркетплейс (CORS не потрібен)
VITE_MARKETPLACE_API=/api

# Origin'и адмінки/маркетплейсу, яким дозволено вбудовувати конструктор у <iframe>
# і обмінюватися postMessage. Список через кому. ОБОВ'ЯЗКОВО вкажіть прод-домен,
# інакше вбудований конструктор у проді не відповідатиме адмінці.
VITE_ALLOWED_PARENT_ORIGINS=http://localhost:5174,http://localhost:5173
