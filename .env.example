# ============================================
# PostgreSQL Database Configuration
# ============================================

# Connection String (Recommended)
DATABASE_URL=postgresql://postgres:Qa121314!@localhost:5432/memory_moments_marketplace

# Individual Database Credentials (Alternative)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=Qa121314!
DATABASE_NAME=memory_moments_marketplace

# Connection Pool Settings (Optional)
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================
# Server Configuration
# ============================================

# Server Port
PORT=3001
HOST=localhost

# Node Environment
NODE_ENV=development

# ============================================
# JWT Authentication
# ============================================

JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRATION=7d

# ============================================
# File Upload
# ============================================

# Upload Directory
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Allowed File Types (comma-separated)
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/webp,image/gif

# ============================================
# CORS Configuration
# ============================================

# Frontend URLs (comma-separated)
CORS_ORIGINS=http://localhost:5174,http://localhost:5173,http://localhost:3000

# ============================================
# Logging
# ============================================

# Log Level (debug, info, warn, error)
LOG_LEVEL=debug

# ============================================
# Email Configuration (Optional)
# ============================================

# SMTP Server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Email Settings
EMAIL_FROM=noreply@memory-moments.local
EMAIL_SUPPORT=support@memory-moments.local

# ============================================
# Storage (Optional)
# ============================================

# Cloud Storage (S3, GCS, etc.)
# STORAGE_TYPE=local
# STORAGE_BUCKET=
# STORAGE_KEY=
# STORAGE_SECRET=

# ============================================
# Admin Credentials (Seed Data)
# ============================================

# Default Admin Email and Password (used for seeding)
ADMIN_EMAIL=admin@memory-moments.local
ADMIN_PASSWORD=change_in_production

# ============================================
# External Services (Optional)
# ============================================

# Payment Gateway
# STRIPE_PUBLIC_KEY=
# STRIPE_SECRET_KEY=

# Analytics
# ANALYTICS_API_KEY=

# ============================================
# Notes
# ============================================
# 
# For Production:
# 1. Change all default passwords
# 2. Use strong JWT_SECRET (256+ characters)
# 3. Enable HTTPS
# 4. Set NODE_ENV=production
# 5. Use managed database service (AWS RDS, etc.)
# 6. Never commit .env file to version control
# 7. Use environment variables for sensitive data
# 8. Enable firewall rules for DB access
#
